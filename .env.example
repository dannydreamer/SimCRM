# ─── Database ─────────────────────────────────────────────────────────────────
# Supabase pooled connection via Supavisor (transaction mode, port 6543) — runtime
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# Supabase direct connection (port 5432) — Prisma migrations only
# Run migrations with: DATABASE_URL=<direct> DIRECT_URL=<direct> npx prisma migrate deploy
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET="your-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"
